# Copy to .env for local dev:  cp .env.example .env
# All values here are PUBLIC (network config + a public contract id). Never put
# secrets or private keys in this file.

# Stellar network: testnet | mainnet
VITE_STELLAR_NETWORK=testnet

# Soroban RPC (default follows network)
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ShuntVault contract id (C...). This is the CURRENT security-hardened testnet
# deployment — it MUST match the keeper's VAULT_CONTRACT_ID (keeper/wrangler.toml).
# Previous deployment: CC7E2HL7SNQ34PFLV74WEQSW2OVBRBG3EUTLKWC3NYKIC4XPPABQWBMW
VITE_VAULT_CONTRACT_ID=CDMFJZ6VRD2JEV7J2W7KMZZ3AXNSOST2C6L2KYRJAYIN7ULWJEOCWO5B

# Keeper API base URL. Production worker below; use http://localhost:8787 for
# local `wrangler dev`.
VITE_KEEPER_URL=https://shunt-keeper.irhamtria.workers.dev

# SEP-24 anchor home domain. Default = SDF test anchor (the only ecosystem
# anchor with a TESTNET SEP-24 endpoint). Swapping corridors is just this one
# value — no contract change. Production candidates (mainnet): IDRX (regulated
# IDR stablecoin) for 🇮🇩, Coins.ph (BSP-licensed) for 🇵🇭.
VITE_ANCHOR_HOME_DOMAIN=testanchor.stellar.org

# Classic USDC asset for the Invest lane path payment (Circle testnet USDC).
VITE_USDC_CODE=USDC
VITE_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
