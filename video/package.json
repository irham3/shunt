{
  "name": "shunt-video",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone Remotion project for the Shunt hero animation. Isolated from the Vite web app.",
  "scripts": {
    "dev": "remotion studio",
    "render:hero": "remotion render ShuntHero out/shunt-hero.mp4",
    "render:still": "remotion still ShuntHero out/shunt-hero.png --frame=160",
    "copy:web": "node scripts/copy-to-web.mjs",
    "build:web": "npm run render:hero && npm run copy:web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0"
  }
}
